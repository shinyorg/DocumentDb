<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Sample.Maui.MainPage"
             Title="DocumentDb Explorer"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#1A1A2E}">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16" RowSpacing="12">

        <!-- Type selector tabs -->
        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                StrokeShape="RoundRectangle 12"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2A2A4A}"
                StrokeThickness="1"
                Padding="12">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button x:Name="BtnCustomers"
                        Text="Customers"
                        Clicked="OnCustomersClicked"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="8"
                        FontSize="13"
                        Padding="16,8"
                        HeightRequest="36" />
                <Button x:Name="BtnOrders"
                        Grid.Column="1"
                        Text="Orders"
                        Clicked="OnOrdersClicked"
                        BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2A2A4A}"
                        TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                        CornerRadius="8"
                        FontSize="13"
                        Padding="16,8"
                        Margin="8,0,0,0"
                        HeightRequest="36" />
                <Border Grid.Column="3"
                        BackgroundColor="{AppThemeBinding Light=#EDE7F6, Dark=#2D1B69}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="10,4">
                    <Label x:Name="CountLabel"
                           VerticalOptions="Center"
                           FontSize="12"
                           TextColor="{StaticResource Primary}" />
                </Border>
            </Grid>
        </Border>

        <!-- SQL WHERE clause input -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                StrokeShape="RoundRectangle 12"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2A2A4A}"
                StrokeThickness="1"
                Padding="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Border StrokeShape="RoundRectangle 8"
                        Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A5A}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#0F3460}"
                        Padding="8,0">
                    <Entry x:Name="SqlEntry"
                           Placeholder="WHERE clause (e.g. json_extract(Data, '$.age') > 30)"
                           PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}"
                           FontFamily="Courier New"
                           FontSize="13"
                           ClearButtonVisibility="WhileEditing"
                           ReturnType="Search"
                           Completed="OnQueryExecuted" />
                </Border>
                <Button Grid.Column="1"
                        Text="Run"
                        Clicked="OnQueryExecuted"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="8"
                        FontSize="13"
                        Padding="20,8"
                        HeightRequest="36" />
            </Grid>
        </Border>

        <!-- Error status -->
        <Label Grid.Row="2" x:Name="StatusLabel" TextColor="#E53935" FontSize="12" Margin="4,0" />

        <!-- Results table -->
        <Border Grid.Row="3"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                StrokeShape="RoundRectangle 12"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2A2A4A}"
                StrokeThickness="1">
            <Grid RowDefinitions="Auto,*">
                <!-- Table header -->
                <Grid x:Name="HeaderGrid"
                      BackgroundColor="{AppThemeBinding Light=#F5F3FF, Dark=#1A1145}"
                      Padding="12,10" />

                <!-- Table rows -->
                <CollectionView Grid.Row="1" x:Name="ResultsView" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
